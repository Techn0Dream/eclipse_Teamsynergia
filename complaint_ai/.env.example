# Complaint AI — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values below.
#   3. NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGO_DB_NAME=complaint_ai

# ── Gemini LLM ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── RAG / FAISS ───────────────────────────────────────────────────────────────
RAG_SAMPLE_LIMIT=5000
RAG_TOP_K=5
RAG_CSV_PATH=data.csv
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/complaint_ai.log

# ── Agent ─────────────────────────────────────────────────────────────────────
# Complaints scored below this threshold are always escalated to HUMAN review
LOW_CONFIDENCE_THRESHOLD=0.5
